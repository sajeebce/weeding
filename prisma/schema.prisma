generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============ USER & AUTH ============
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  phone         String?
  country       String?
  image         String?
  password      String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)

  accounts       Account[]
  sessions       Session[]
  orders         Order[]
  documents      Document[]
  paymentMethods PaymentMethod[]

  // Support ticket relations
  customerTickets   SupportTicket[]   @relation("CustomerTickets")
  assignedTickets   SupportTicket[]   @relation("AssignedTickets")
  sentMessages      SupportMessage[]  @relation("SentMessages")
  authoredNotes     InternalNote[]    @relation("AuthoredNotes")
  cannedResponses   CannedResponse[]  @relation("CreatedCannedResponses")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

enum UserRole {
  CUSTOMER
  ADMIN
  CONTENT_MANAGER
  SALES_AGENT
  SUPPORT_AGENT
}

// Feature value types for comparison table
enum FeatureValueType {
  BOOLEAN    // Shows ✓ or ✗
  TEXT       // Shows customValue text
  ADDON      // Shows "+ $XX" button (clickable add-on)
  DASH       // Shows — (not applicable)
}

// ============ ROLE PERMISSIONS ============
model RolePermission {
  id         String   @id @default(cuid())
  role       UserRole
  permission String   // e.g., "users.view", "blog.create"
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ SERVICE CATEGORIES ============
model ServiceCategory {
  id          String    @id @default(cuid())
  name        String    // "Formation & Legal"
  slug        String    @unique // "formation"
  description String?
  icon        String?   // Icon name from lucide-react
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)

  services    Service[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isActive])
}

// ============ SERVICES & PACKAGES ============
model Service {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  shortDesc       String   @db.Text // Short description for cards
  description     String   @db.Text // Rich HTML content (Sun Editor)
  icon            String?  // Icon name from lucide-react
  image           String?  // Image URL (Cloudflare R2)
  startingPrice   Decimal  @default(0) @db.Decimal(10, 2) // Lowest package price
  processingTime  String?  // "3-5 business days"
  isPopular       Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  // Category relation
  categoryId      String?
  category        ServiceCategory? @relation(fields: [categoryId], references: [id])

  // Relations
  packages        Package[]
  features        ServiceFeature[]
  faqs            ServiceFAQ[]
  orderItems      OrderItem[]
  formTemplate    ServiceFormTemplate?

  // SEO
  metaTitle       String?
  metaDescription String?
  keywords        String[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([categoryId])
  @@index([isPopular])
}

// Service features - Master list for comparison table
model ServiceFeature {
  id          String  @id @default(cuid())
  text        String  // "Employer Identification Number (EIN)"
  description String? @db.Text // Detailed description (optional)
  tooltip     String? // Short tooltip shown on hover in table
  sortOrder   Int     @default(0)

  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Which packages include this feature
  packageMappings PackageFeatureMap[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceId])
}

// Service-specific FAQs
model ServiceFAQ {
  id        String  @id @default(cuid())
  question  String
  answer    String  @db.Text // Can be rich text
  sortOrder Int     @default(0)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Package {
  id          String   @id @default(cuid())
  serviceId   String
  name        String   // "Basic", "Standard", "Premium"
  description String?  @db.Text // Package tagline
  priceUSD    Decimal  @db.Decimal(10, 2)
  priceBDT    Decimal? @db.Decimal(10, 2)
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  // Processing time display
  processingTime     String?  // "3 weeks", "3 business days"
  processingTimeNote String?  // "(instead of 3 weeks)"
  processingIcon     String?  // "clock" or "zap" for fast

  // Badge/label for package
  badgeText   String?  // "Recommended", "Best Value", "Most Popular"
  badgeColor  String?  // "orange", "green", "blue"

  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  features    PackageFeature[]
  notIncluded PackageNotIncluded[]
  featureMap  PackageFeatureMap[]  // For comparison table
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceId])
  @@index([isActive])
}

// Package included features
model PackageFeature {
  id        String  @id @default(cuid())
  text      String  // "EIN Application"
  sortOrder Int     @default(0)

  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

// Package not-included features (legacy - keep for backward compatibility)
model PackageNotIncluded {
  id        String  @id @default(cuid())
  text      String  // "Virtual Address"
  sortOrder Int     @default(0)

  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

// Junction table: Package <-> ServiceFeature (for comparison table)
model PackageFeatureMap {
  id          String  @id @default(cuid())

  packageId   String
  package     Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  featureId   String
  feature     ServiceFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  included    Boolean @default(true)  // true = ✓, false = ✗
  customValue String? // Optional: "10 per month" instead of just ✓

  // New fields for enhanced comparison table
  valueType     FeatureValueType @default(BOOLEAN)  // BOOLEAN, TEXT, ADDON, DASH
  addonPriceUSD Decimal?         @db.Decimal(10, 2) // Add-on price if valueType=ADDON
  addonPriceBDT Decimal?         @db.Decimal(10, 2) // BDT price for addon

  @@unique([packageId, featureId])
  @@index([packageId])
  @@index([featureId])
}

// ============ ORDERS & PAYMENTS ============
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  status          OrderStatus @default(PENDING)

  // Pricing
  subtotalUSD     Decimal     @db.Decimal(10, 2)
  discountUSD     Decimal     @default(0) @db.Decimal(10, 2)
  totalUSD        Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  exchangeRate    Decimal?    @db.Decimal(10, 4)

  // Payment
  paymentMethod   String?
  paymentStatus   PaymentStatus @default(PENDING)
  paymentId       String?
  paidAt          DateTime?

  // LLC Details
  llcName         String?
  llcState        String?
  llcType         String?

  // Contact
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerCountry String?

  // Coupon
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])

  // Relations
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  documents       Document[]
  notes           OrderNote[]
  invoices        Invoice[]
  tickets         SupportTicket[]
  formSubmissions FormSubmission[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  PROCESSING
  IN_PROGRESS
  WAITING_FOR_INFO
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  serviceId   String
  packageId   String?

  name        String
  description String?
  quantity    Int      @default(1)
  priceUSD    Decimal  @db.Decimal(10, 2)
  stateFee    Decimal? @db.Decimal(10, 2)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id])
  package     Package? @relation(fields: [packageId], references: [id])

  createdAt   DateTime @default(now())

  @@index([orderId])
}

model OrderNote {
  id          String   @id @default(cuid())
  orderId     String
  authorId    String?
  content     String   @db.Text
  isInternal  Boolean  @default(false)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([orderId])
}

// ============ DOCUMENTS ============
model Document {
  id          String         @id @default(cuid())
  orderId     String?
  userId      String
  type        DocumentType
  name        String
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  status      DocumentStatus @default(PENDING)

  order       Order?         @relation(fields: [orderId], references: [id])
  user        User           @relation(fields: [userId], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

enum DocumentType {
  PASSPORT
  ID_CARD
  ADDRESS_PROOF
  ARTICLES_OF_ORG
  EIN_LETTER
  OPERATING_AGREEMENT
  BANK_STATEMENT
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ============ INVOICES ============
model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  orderId       String

  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  tax           Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")

  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  paidAt        DateTime?

  order         Order         @relation(fields: [orderId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ============ SUPPORT TICKETS ============
model SupportTicket {
  id              String         @id @default(cuid())
  ticketNumber    String         @unique // TKT-001, TKT-002
  subject         String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  category        String?

  // Customer (registered or guest)
  customerId      String?
  customer        User?          @relation("CustomerTickets", fields: [customerId], references: [id])
  guestName       String?
  guestEmail      String?
  guestPhone      String?

  // Assignment
  assignedToId    String?
  assignedTo      User?          @relation("AssignedTickets", fields: [assignedToId], references: [id])

  // Related order
  orderId         String?
  order           Order?         @relation(fields: [orderId], references: [id])

  // Source & metadata
  source          TicketSource   @default(LIVE_CHAT)
  ipAddress       String?
  userAgent       String?

  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?

  // Relations
  messages        SupportMessage[]
  internalNotes   InternalNote[]

  @@index([customerId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([ticketNumber])
  @@index([createdAt])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  WAITING_FOR_AGENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketSource {
  LIVE_CHAT
  EMAIL
  MANUAL
  API
}

model SupportMessage {
  id          String      @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Message content
  content     String      @db.Text
  contentHtml String?     @db.Text

  // Sender info
  senderId    String?
  sender      User?       @relation("SentMessages", fields: [senderId], references: [id])
  senderType  SenderType  // CUSTOMER, AGENT, SYSTEM
  senderName  String      // Display name (for guests)

  // Message type
  type        MessageType @default(TEXT)

  // Attachments
  attachments MessageAttachment[]

  // Status
  isRead      Boolean     @default(false)
  readAt      DateTime?

  createdAt   DateTime    @default(now())

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
}

enum SenderType {
  CUSTOMER
  AGENT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  SYSTEM
}

model MessageAttachment {
  id          String         @id @default(cuid())
  messageId   String
  message     SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  fileName    String
  fileUrl     String
  fileType    String         // image/jpeg, application/pdf, etc.
  fileSize    Int            // in bytes

  createdAt   DateTime       @default(now())

  @@index([messageId])
}

model InternalNote {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  content     String        @db.Text
  authorId    String
  author      User          @relation("AuthoredNotes", fields: [authorId], references: [id])

  // Mentions (array of user IDs)
  mentions    String[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ticketId])
  @@index([authorId])
}

model CannedResponse {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  category    String?

  // Usage tracking
  useCount    Int      @default(0)

  // Ownership
  createdById String
  createdBy   User     @relation("CreatedCannedResponses", fields: [createdById], references: [id])
  isPublic    Boolean  @default(true) // Available to all agents

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdById])
}

// ============ CONTENT ============
model BlogPost {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  excerpt       String?     @db.Text
  content       String      @db.Text
  coverImage    String?
  authorId      String?
  status        PostStatus  @default(DRAFT)
  publishedAt   DateTime?

  categories    BlogCategory[]
  tags          String[]

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?

  // Hierarchical relationship
  parentId    String?
  parent      BlogCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    BlogCategory[] @relation("CategoryHierarchy")

  posts       BlogPost[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  @@index([slug])
  @@index([parentId])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  company     String?
  country     String?
  avatar      String?
  content     String   @db.Text
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([isActive])
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String   @db.Text
  category    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([category])
}

// ============ SETTINGS ============
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")

  updatedAt DateTime @updatedAt

  @@index([key])
}

// ============ STATE FEES ============
model StateFee {
  id              String   @id @default(cuid())
  stateCode       String   @unique
  stateName       String
  llcFee          Decimal  @db.Decimal(10, 2)
  annualFee       Decimal? @db.Decimal(10, 2)
  processingTime  String?
  isPopular       Boolean  @default(false)

  // SEO for state landing pages
  metaTitle       String?
  metaDescription String?
  content         String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stateCode])
  @@index([isPopular])
}

// ============ COUPONS ============
model Coupon {
  id          String      @id @default(cuid())
  code        String      @unique
  description String?
  type        CouponType  @default(PERCENTAGE)
  value       Decimal     @db.Decimal(10, 2)
  minOrder    Decimal?    @db.Decimal(10, 2)
  maxDiscount Decimal?    @db.Decimal(10, 2)
  usageLimit  Int?
  usedCount   Int         @default(0)
  isActive    Boolean     @default(true)
  expiresAt   DateTime?

  orders      Order[]

  createdAt   DateTime    @default(now())

  @@index([code])
  @@index([isActive])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

// ============ PAYMENT METHODS ============
model PaymentMethod {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Card details (stored securely - only last 4 digits)
  type            String   @default("card") // card, bank, paypal
  brand           String?  // visa, mastercard, amex
  last4           String   // last 4 digits of card
  expiryMonth     Int?
  expiryYear      Int?
  cardholderName  String?

  // Stripe/Payment provider ID
  stripePaymentMethodId String?  @unique
  stripeCustomerId      String?

  // Status
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([stripePaymentMethodId])
}

// ============ ACTIVITY LOG ============
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ipAddress   String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ============ LEGAL PAGES ============
model LegalPage {
  id          String   @id @default(cuid())
  slug        String   @unique // "terms", "privacy", "refund-policy", "disclaimer"
  title       String   // "Terms of Service"
  content     String   @db.Text // Rich HTML content (Sun Editor)
  isActive    Boolean  @default(true)

  // SEO
  metaTitle       String?
  metaDescription String?

  // Version tracking
  version     Int      @default(1)
  lastUpdatedBy String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

// ============================================
// DYNAMIC FORM BUILDER
// ============================================

// Form template for each service
model ServiceFormTemplate {
  id          String   @id @default(cuid())
  serviceId   String   @unique
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Template metadata
  version     Int      @default(1)
  isActive    Boolean  @default(true)

  // Relations
  tabs        FormTab[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Form tabs (steps)
model FormTab {
  id          String   @id @default(cuid())
  templateId  String
  template    ServiceFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Tab configuration
  name        String       // "Personal Information"
  description String?      // "Your basic personal details"
  icon        String?      // "user", "map-pin", "file-text"
  order       Int          // 1, 2, 3...

  // Relations
  fields      FormField[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([templateId, order])
}

// Individual form fields
model FormField {
  id              String   @id @default(cuid())
  tabId           String
  tab             FormTab  @relation(fields: [tabId], references: [id], onDelete: Cascade)

  // Field identity
  name            String       // "firstName", "dateOfBirth"
  label           String       // "First Name", "Date of Birth"
  type            FieldType

  // Display
  placeholder     String?
  helpText        String?      // Tooltip/info text
  order           Int
  width           FieldWidth   @default(FULL)

  // Validation
  required        Boolean      @default(false)
  validation      Json?        // { minLength, maxLength, pattern, min, max }

  // Options (for select, radio, checkbox)
  options         Json?        // [{ value, label, description? }]

  // Data source (for dynamic options)
  dataSourceType  DataSourceType?
  dataSourceKey   String?      // "countries", "states", "custom:business_types"
  dependsOn       String?      // Field name this depends on (e.g., state depends on country)

  // Conditional rendering
  conditionalLogic Json?       // { show: true, when: "fieldName", operator: "equals", value: "X" }

  // File upload settings
  accept          String?      // ".pdf,.jpg,.png"
  maxSize         Int?         // Max file size in MB

  // Default value
  defaultValue    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tabId, order])
}

enum FieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  DATE
  TEXTAREA
  SELECT
  MULTI_SELECT
  RADIO
  CHECKBOX
  CHECKBOX_GROUP
  FILE_UPLOAD
  IMAGE_UPLOAD
  COUNTRY_SELECT
  STATE_SELECT
  ADDRESS
  SIGNATURE
  RICH_TEXT
  HEADING
  PARAGRAPH
  DIVIDER
}

enum FieldWidth {
  FULL
  HALF
  THIRD
  TWO_THIRD
}

enum DataSourceType {
  STATIC
  COUNTRY_LIST
  STATE_LIST
  CURRENCY_LIST
  CUSTOM_LIST
  API_ENDPOINT
}

// ============================================
// DYNAMIC DATA LISTS
// ============================================

// System-managed lists (countries, currencies, etc.)
model SystemList {
  id             String   @id @default(cuid())
  key            String   @unique  // "countries", "currencies", "us_states"
  name           String            // "Countries", "Currencies"
  description    String?
  type           String            // "country", "state", "currency", "general"

  // Settings
  isEditable     Boolean  @default(false)  // Can admin edit?
  isHierarchical Boolean  @default(false)  // Has parent-child relationship?

  // Relations
  items          SystemListItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Items in system lists
model SystemListItem {
  id          String   @id @default(cuid())
  listId      String
  list        SystemList @relation(fields: [listId], references: [id], onDelete: Cascade)

  // Item data
  value       String       // "US", "BD", "USD"
  label       String       // "United States", "Bangladesh"
  code        String?      // ISO code or short code
  icon        String?      // Flag emoji or icon name

  // Additional data
  metadata    Json?        // { phoneCode: "+1", symbol: "$", etc. }

  // Hierarchy (for states -> country relationship)
  parentId    String?
  parent      SystemListItem? @relation("ItemHierarchy", fields: [parentId], references: [id])
  children    SystemListItem[] @relation("ItemHierarchy")

  // Display
  order       Int          @default(0)
  isPopular   Boolean      @default(false)  // Show in quick select
  isActive    Boolean      @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([listId, value])
  @@index([listId, parentId])
  @@index([listId, isPopular])
}

// Custom lists created by admin
model CustomList {
  id          String   @id @default(cuid())
  key         String   @unique  // "business_types", "industry_types"
  name        String
  description String?

  items       CustomListItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomListItem {
  id          String   @id @default(cuid())
  listId      String
  list        CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)

  value       String
  label       String
  description String?
  metadata    Json?
  order       Int          @default(0)
  isActive    Boolean      @default(true)

  @@index([listId, order])
}

// ============================================
// FORM SUBMISSIONS
// ============================================

// Store form submission data
model FormSubmission {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Form template reference
  templateId      String
  templateVersion Int      // Which version of form was used

  // Submission data
  data            Json     // All form field values as JSON

  // Status tracking
  status          SubmissionStatus @default(DRAFT)

  // Files
  files           FormSubmissionFile[]

  submittedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([templateId])
}

model FormSubmissionFile {
  id              String   @id @default(cuid())
  submissionId    String
  submission      FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  fieldName       String   // Which form field
  fileName        String
  fileUrl         String
  fileSize        Int
  mimeType        String

  createdAt       DateTime @default(now())

  @@index([submissionId])
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

// ============================================
// DYNAMIC HEADER & FOOTER BUILDER
// ============================================

// Header Configuration
model HeaderConfig {
  id              String       @id @default(cuid())
  name            String       @default("Default Header")
  isActive        Boolean      @default(true)

  // Layout Settings
  layout          HeaderLayout @default(DEFAULT)
  sticky          Boolean      @default(true)
  transparent     Boolean      @default(false)

  // Top Bar
  topBarEnabled   Boolean      @default(false)
  topBarContent   Json?        // { text, links, showSocial }
  topBarBgColor   String?
  topBarTextColor String?

  // Logo Settings
  logoPosition    LogoPosition @default(LEFT)
  logoMaxHeight   Int          @default(56)

  // CTA Buttons
  ctaButtons      Json?        // [{ text, url, variant, icon }]

  // Auth Buttons
  showAuthButtons Boolean      @default(true)
  loginText       String       @default("Sign In")
  loginUrl        String       @default("/auth/signin")
  loginStyle      Json?        // ButtonCustomStyle
  registerText    String       @default("Get Started")
  registerUrl     String       @default("/services/llc-formation")
  registerStyle   Json?        // ButtonCustomStyle

  // Search
  searchEnabled   Boolean      @default(false)

  // Mobile Settings
  mobileBreakpoint Int         @default(1024)

  // Styling
  bgColor         String?
  textColor       String?
  hoverColor      String?      // Menu hover color
  accentColor     String?
  borderColor     String?
  height          Int          @default(64)

  // Relations
  menuItems       MenuItem[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum HeaderLayout {
  DEFAULT       // Logo left, Nav center, CTA right
  CENTERED      // Logo center, Nav below
  SPLIT         // Logo center, Nav split left/right
  MINIMAL       // Logo left, Hamburger right
  MEGA          // Full mega menu style
}

enum LogoPosition {
  LEFT
  CENTER
  RIGHT
}

// Navigation Menu Items (for both Header and Footer)
model MenuItem {
  id              String     @id @default(cuid())

  // Basic Info
  label           String
  url             String?
  target          String     @default("_self") // _self, _blank
  icon            String?    // Lucide icon name

  // Hierarchy
  parentId        String?
  parent          MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children        MenuItem[] @relation("MenuHierarchy")

  // Mega Menu Content (for parent items)
  isMegaMenu      Boolean    @default(false)
  megaMenuColumns Int?       @default(4)
  megaMenuContent Json?      // Custom content blocks

  // Visibility
  isVisible       Boolean    @default(true)
  visibleOnMobile Boolean    @default(true)
  requiredRole    String?    // null = public, CUSTOMER, ADMIN

  // Badge/Label
  badge           String?    // "New", "Popular", "Sale"
  badgeColor      String?

  // Category grouping (for mega menu)
  categoryName    String?    // "Formation & Legal"
  categoryIcon    String?    // "building-2"
  categoryDesc    String?    // "Start your US business"

  // Ordering
  sortOrder       Int        @default(0)

  // Relations
  headerId        String?
  header          HeaderConfig? @relation(fields: [headerId], references: [id], onDelete: Cascade)

  footerWidgetId  String?
  footerWidget    FooterWidget? @relation(fields: [footerWidgetId], references: [id], onDelete: Cascade)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([parentId])
  @@index([headerId])
  @@index([footerWidgetId])
  @@index([sortOrder])
}

// Footer Configuration
model FooterConfig {
  id                   String       @id @default(cuid())
  name                 String       @default("Default Footer")
  isActive             Boolean      @default(true)

  // Layout
  layout               FooterLayout @default(MULTI_COLUMN)
  columns              Int          @default(4)

  // Responsive Columns (Phase 3)
  responsiveColumns    Json?        // { mobile: 1, tablet: 2, desktop: 4 }
  sectionOrder         String[]     @default(["widgets", "newsletter", "trust", "bottom"])

  // Newsletter
  newsletterEnabled    Boolean      @default(true)
  newsletterTitle      String       @default("Subscribe to our newsletter")
  newsletterSubtitle   String?
  newsletterProvider   String?      // mailchimp, convertkit, brevo, custom
  newsletterFormAction String?

  // Social Links (override from business config)
  showSocialLinks      Boolean      @default(true)
  socialPosition       String       @default("brand") // brand, bottom, separate-column

  // Contact Info
  showContactInfo      Boolean      @default(true)
  contactPosition      String       @default("brand") // brand, separate-column

  // Bottom Bar
  bottomBarEnabled     Boolean      @default(true)
  bottomBarLayout      String       @default("split") // split, centered, stacked
  copyrightText        String?
  showDisclaimer       Boolean      @default(true)
  disclaimerText       String?
  bottomLinks          Json?        // [{ label, url }]

  // Trust Badges
  showTrustBadges      Boolean      @default(false)
  trustBadges          Json?        // [{ image, alt, url }]

  // Background Styling (Phase 3)
  bgType               String       @default("solid") // solid, gradient, pattern, image
  bgColor              String?
  bgGradient           Json?        // { type, colors: [{color, position}], angle }
  bgPattern            String?      // dots, grid, waves, geometric
  bgPatternColor       String?
  bgPatternOpacity     Float?       @default(0.1)
  bgImage              String?
  bgImageOverlay       String?

  // Text Styling
  textColor            String?
  headingColor         String?
  linkColor            String?
  linkHoverColor       String?
  accentColor          String?
  borderColor          String?

  // Typography (Phase 3)
  headingFont          String?
  bodyFont             String?
  headingSize          String       @default("sm") // sm, base, lg, xl
  headingWeight        String       @default("semibold") // medium, semibold, bold
  headingStyle         String       @default("normal") // normal, uppercase, capitalize

  // Divider Styling
  dividerStyle         String       @default("solid") // none, solid, dashed, gradient
  dividerColor         String?

  // Social Icon Styling (Phase 3)
  socialShape          String       @default("circle") // circle, square, rounded, pill
  socialSize           String       @default("md") // sm, md, lg, xl
  socialColorMode      String       @default("brand") // brand, monochrome, accent
  socialHoverEffect    String       @default("scale") // scale, lift, glow, rotate
  socialBgStyle        String       @default("subtle") // none, subtle, solid, outline

  // Effects & Animation (Phase 3)
  enableAnimations     Boolean      @default(false)
  entranceAnimation    String?      // fade-up, fade-in, slide-up, stagger
  animationDuration    Int          @default(300)
  linkHoverEffect      String       @default("color") // underline, color, arrow, highlight
  topBorderStyle       String       @default("none") // none, solid, gradient, wave
  topBorderHeight      Int          @default(4)
  topBorderColor       String?

  // Shadow
  shadow               String       @default("none") // none, sm, md, lg, xl
  borderRadius         Int          @default(0)

  // Container Width & Style
  containerWidth       String       @default("full") // full, boxed
  containerStyle       String       @default("sharp") // sharp, round
  cornerRadiusTL       Int          @default(0) // top-left
  cornerRadiusTR       Int          @default(0) // top-right
  cornerRadiusBL       Int          @default(0) // bottom-left
  cornerRadiusBR       Int          @default(0) // bottom-right

  // Spacing
  paddingTop           Int          @default(48)
  paddingBottom        Int          @default(32)

  // Advanced (Phase 6)
  customCSS            String?      @db.Text
  customJS             String?      @db.Text

  // Preset Reference
  presetId             String?
  preset               FooterPreset? @relation(fields: [presetId], references: [id])

  // Relations
  widgets              FooterWidget[]

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// Footer Preset (Phase 1)
model FooterPreset {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("professional") // minimal, professional, modern, creative, industry
  thumbnail   String?  // Preview image URL

  // Preset Configuration
  config      Json     // Full footer configuration snapshot

  // Metadata
  isBuiltIn   Boolean  @default(false) // System presets
  isPublic    Boolean  @default(true)  // Available to all users
  usageCount  Int      @default(0)

  // Feature tags
  tags        String[] // ["dark-mode", "animated", "minimal", "responsive"]

  // Color palette preview
  colorPalette Json?   // { primary, secondary, accent, text, bg }

  // Relation
  footers     FooterConfig[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isBuiltIn])
  @@index([isPublic])
}

enum FooterLayout {
  MULTI_COLUMN   // Traditional multi-column
  CENTERED       // Centered stacked
  MINIMAL        // Just copyright and links
  MEGA           // Full sitemap style
  // New layouts (Phase 2)
  STACKED        // Full-width vertical sections
  ASYMMETRIC     // 2:1 ratio split layout
  MEGA_PLUS      // Mega with featured CTA
  APP_FOCUSED    // Prominent app download section
  NEWSLETTER_HERO // Large newsletter signup as hero
}

// Footer Widgets
model FooterWidget {
  id              String           @id @default(cuid())
  footerId        String
  footer          FooterConfig     @relation(fields: [footerId], references: [id], onDelete: Cascade)

  // Widget Type
  type            FooterWidgetType

  // Basic Settings
  title           String?
  showTitle       Boolean          @default(true)

  // Content based on type
  content         Json?            // Varies by widget type

  // Position
  column          Int              @default(1) // 1-6
  sortOrder       Int              @default(0)

  // Styling
  customClass     String?

  // Relations (for LINKS type)
  menuItems       MenuItem[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([footerId])
  @@index([column, sortOrder])
}

enum FooterWidgetType {
  BRAND           // Logo + description
  LINKS           // Link list
  CONTACT         // Contact info
  NEWSLETTER      // Email subscription
  SOCIAL          // Social icons
  TEXT            // Custom text/HTML
  RECENT_POSTS    // Latest blog posts
  SERVICES        // Services list (auto-populated)
  STATES          // Popular states (auto-populated)
  CUSTOM_HTML     // Raw HTML
  // New widget types (Phase 4)
  APP_DOWNLOAD    // App store badges with QR code
  PAYMENT_METHODS // Payment provider icons
  AWARDS          // Certifications and badges
  MAP             // Embedded location map
  WORKING_HOURS   // Business hours display
  LANGUAGE_SELECT // Multi-language dropdown
  THEME_TOGGLE    // Dark/light mode switcher
  FEATURED_PRODUCT // Highlighted product card
  TESTIMONIAL     // Single rotating testimonial
  COUNTDOWN       // Event countdown timer
  CTA_BANNER      // Call-to-action banner
  BUTTON          // Custom styled button widget
}

// Newsletter Subscriber
model NewsletterSubscriber {
  id           String                   @id @default(cuid())
  email        String                   @unique
  name         String?
  status       NewsletterSubscriberStatus @default(ACTIVE)
  source       String?                  // website, import, api
  subscribedAt DateTime                 @default(now())
  unsubscribedAt DateTime?
  confirmedAt  DateTime?                // For double opt-in
  metadata     Json?                    // Additional data (IP, user agent, etc.)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([status])
  @@index([subscribedAt])
}

enum NewsletterSubscriberStatus {
  PENDING     // Awaiting confirmation (double opt-in)
  ACTIVE      // Confirmed and active
  UNSUBSCRIBED
  BOUNCED
}

// ============================================
// LANDING PAGE BUILDER
// ============================================

// Landing page definition
model LandingPage {
  id              String   @id @default(cuid())
  slug            String   @unique // "homepage", "llc-landing", etc.
  name            String   // "Homepage", "LLC Landing Page"
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false) // Is this the main homepage?

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // Page blocks
  blocks          LandingPageBlock[]

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime?

  // Versioning
  version         Int      @default(1)

  @@index([slug])
  @@index([isActive, isDefault])
}

// Individual block on a landing page
model LandingPageBlock {
  id            String      @id @default(cuid())
  landingPageId String
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  // Block identity
  type          String      // "hero", "services-grid", "testimonials", etc.
  name          String?     // Optional custom name for admin reference
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)

  // Block settings (JSON)
  settings      Json        // Type-specific settings

  // Responsive visibility
  hideOnMobile  Boolean     @default(false)
  hideOnDesktop Boolean     @default(false)

  // A/B Testing (future)
  variant       String?     // "A", "B", "C" for A/B testing

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([landingPageId, sortOrder])
  @@index([landingPageId, isActive])
}

// Reusable block templates
model BlockTemplate {
  id          String   @id @default(cuid())
  name        String   // "Bizee-style Hero", "Minimal CTA"
  category    String   // "hero", "cta", "testimonials"
  type        String   // Block type this template is for
  settings    Json     // Pre-configured settings
  thumbnail   String?  // Preview image URL
  isBuiltIn   Boolean  @default(false) // System template vs user-created

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([type])
}
