generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String           @id @default(cuid())
  email               String           @unique
  emailVerified       DateTime?
  name                String?
  phone               String?
  country             String?
  image               String?
  password            String?
  role                UserRole         @default(CUSTOMER)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  isActive            Boolean          @default(true)
  accounts            Account[]
  cannedResponses     CannedResponse[] @relation("CreatedCannedResponses")
  documents           Document[]
  authoredNotes       InternalNote[]   @relation("AuthoredNotes")
  invoices            Invoice[]
  assignedLeads       Lead[]           @relation("AssignedLeads")
  performedActivities LeadActivity[]   @relation("PerformedActivities")
  authoredLeadNotes   LeadNote[]       @relation("AuthoredLeadNotes")
  orders              Order[]
  paymentMethods      PaymentMethod[]
  sessions            Session[]
  sentMessages        SupportMessage[] @relation("SentMessages")
  assignedTickets     SupportTicket[]  @relation("AssignedTickets")
  customerTickets     SupportTicket[]  @relation("CustomerTickets")

  @@index([email])
  @@index([role])
}

model RolePermission {
  id         String   @id @default(cuid())
  role       UserRole
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]

  @@index([slug])
  @@index([isActive])
}

model Service {
  id                      String               @id @default(cuid())
  name                    String
  slug                    String               @unique
  shortDesc               String
  description             String
  icon                    String?
  image                   String?
  startingPrice           Decimal              @default(0) @db.Decimal(10, 2)
  processingTime          String?
  isPopular               Boolean              @default(false)
  isActive                Boolean              @default(true)
  sortOrder               Int                  @default(0)
  categoryId              String?
  metaTitle               String?
  metaDescription         String?
  keywords                String[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  displayOptions          Json                 @default("{}")
  hasLocationBasedPricing Boolean              @default(false)
  locationFeeLabel        String?
  locationFees            LocationFee[]
  orderItems              OrderItem[]
  packages                Package[]
  category                ServiceCategory?     @relation(fields: [categoryId], references: [id])
  faqs                    ServiceFAQ[]
  features                ServiceFeature[]
  formTemplate            ServiceFormTemplate?

  @@index([slug])
  @@index([isActive])
  @@index([categoryId])
  @@index([isPopular])
}

model ServiceFeature {
  id              String              @id @default(cuid())
  text            String
  sortOrder       Int                 @default(0)
  serviceId       String
  createdAt       DateTime            @default(now())
  description     String?
  tooltip         String?
  updatedAt       DateTime            @updatedAt
  packageMappings PackageFeatureMap[]
  service         Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model ServiceFAQ {
  id        String  @id @default(cuid())
  question  String
  answer    String
  sortOrder Int     @default(0)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Package {
  id                 String               @id @default(cuid())
  serviceId          String
  name               String
  description        String?
  priceUSD           Decimal              @db.Decimal(10, 2)
  priceBDT           Decimal?             @db.Decimal(10, 2)
  isPopular          Boolean              @default(false)
  isActive           Boolean              @default(true)
  sortOrder          Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  badgeColor         String?
  badgeText          String?
  processingIcon     String?
  processingTime     String?
  processingTimeNote String?
  orderItems         OrderItem[]
  service            Service              @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  features           PackageFeature[]
  featureMap         PackageFeatureMap[]
  notIncluded        PackageNotIncluded[]

  @@index([serviceId])
  @@index([isActive])
}

model PackageFeature {
  id        String  @id @default(cuid())
  text      String
  sortOrder Int     @default(0)
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model PackageNotIncluded {
  id        String  @id @default(cuid())
  text      String
  sortOrder Int     @default(0)
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model PackageFeatureMap {
  id            String           @id @default(cuid())
  packageId     String
  featureId     String
  included      Boolean          @default(true)
  customValue   String?
  valueType     FeatureValueType @default(BOOLEAN)
  addonPriceUSD Decimal?         @db.Decimal(10, 2)
  addonPriceBDT Decimal?         @db.Decimal(10, 2)
  feature       ServiceFeature   @relation(fields: [featureId], references: [id], onDelete: Cascade)
  package       Package          @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, featureId])
  @@index([packageId])
  @@index([featureId])
}

model Order {
  id              String           @id @default(cuid())
  orderNumber     String           @unique
  userId          String
  status          OrderStatus      @default(PENDING)
  subtotalUSD     Decimal          @db.Decimal(10, 2)
  discountUSD     Decimal          @default(0) @db.Decimal(10, 2)
  totalUSD        Decimal          @db.Decimal(10, 2)
  currency        String           @default("USD")
  exchangeRate    Decimal?         @db.Decimal(10, 4)
  paymentMethod   String?
  paymentStatus   PaymentStatus    @default(PENDING)
  paymentId       String?
  paidAt          DateTime?
  llcName         String?
  llcState        String?
  llcType         String?
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerCountry String?
  couponId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  documents       Document[]
  formSubmissions FormSubmission[]
  invoices        Invoice[]
  coupon          Coupon?          @relation(fields: [couponId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  items           OrderItem[]
  notes           OrderNote[]
  tickets         SupportTicket[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  serviceId        String?
  packageId        String?
  name             String
  description      String?
  quantity         Int      @default(1)
  priceUSD         Decimal  @db.Decimal(10, 2)
  stateFee         Decimal? @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  locationCode     String?
  locationFeeLabel String?
  locationId       String?
  locationName     String?
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package          Package? @relation(fields: [packageId], references: [id])
  service          Service? @relation(fields: [serviceId], references: [id])

  @@index([orderId])
}

model OrderNote {
  id         String   @id @default(cuid())
  orderId    String
  authorId   String?
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Document {
  id        String         @id @default(cuid())
  orderId   String?
  userId    String
  type      DocumentType
  name      String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  status    DocumentStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  order     Order?         @relation(fields: [orderId], references: [id])
  user      User           @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  orderId         String?
  subtotal        Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customerCountry String?
  customerEmail   String
  customerName    String
  customerPhone   String?
  items           Json?
  notes           String?
  serviceName     String?
  userId          String
  order           Order?        @relation(fields: [orderId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([serviceName])
}

model SupportTicket {
  id              String           @id @default(cuid())
  ticketNumber    String           @unique
  subject         String
  status          TicketStatus     @default(OPEN)
  priority        TicketPriority   @default(MEDIUM)
  category        String?
  customerId      String?
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  assignedToId    String?
  orderId         String?
  source          TicketSource     @default(LIVE_CHAT)
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  aiResponses     AIResponse[]
  internalNotes   InternalNote[]
  messages        SupportMessage[]
  assignedTo      User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  customer        User?            @relation("CustomerTickets", fields: [customerId], references: [id])
  order           Order?           @relation(fields: [orderId], references: [id])

  @@index([customerId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([ticketNumber])
  @@index([createdAt])
}

model SupportMessage {
  id          String              @id @default(cuid())
  ticketId    String
  content     String
  contentHtml String?
  senderId    String?
  senderType  SenderType
  senderName  String
  type        MessageType         @default(TEXT)
  isRead      Boolean             @default(false)
  readAt      DateTime?
  createdAt   DateTime            @default(now())
  attachments MessageAttachment[]
  sender      User?               @relation("SentMessages", fields: [senderId], references: [id])
  ticket      SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
}

model MessageAttachment {
  id        String         @id @default(cuid())
  messageId String
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime       @default(now())
  message   SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model InternalNote {
  id        String        @id @default(cuid())
  ticketId  String
  content   String
  authorId  String
  mentions  String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  author    User          @relation("AuthoredNotes", fields: [authorId], references: [id])
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
}

model CannedResponse {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String?
  useCount    Int      @default(0)
  createdById String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation("CreatedCannedResponses", fields: [createdById], references: [id])

  @@index([category])
  @@index([createdById])
}

model BlogPost {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  excerpt         String?
  content         String
  coverImage      String?
  authorId        String?
  status          PostStatus     @default(DRAFT)
  publishedAt     DateTime?
  tags            String[]
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  categories      BlogCategory[] @relation("BlogCategoryToBlogPost")

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
}

model BlogCategory {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  parentId    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
  parent      BlogCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    BlogCategory[] @relation("CategoryHierarchy")
  posts       BlogPost[]     @relation("BlogCategoryToBlogPost")

  @@index([slug])
  @@index([parentId])
}

model Testimonial {
  id           String          @id @default(cuid())
  name         String
  company      String?
  country      String?
  avatar       String?
  content      String
  rating       Int             @default(5)
  isActive     Boolean         @default(true)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  tags         String[]
  thumbnailUrl String?
  type         TestimonialType @default(PHOTO)
  videoUrl     String?

  @@index([isActive])
  @@index([type])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([category])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  updatedAt DateTime @updatedAt

  @@index([key])
}

model StateFee {
  id              String   @id @default(cuid())
  stateCode       String   @unique
  stateName       String
  llcFee          Decimal  @db.Decimal(10, 2)
  annualFee       Decimal? @db.Decimal(10, 2)
  processingTime  String?
  isPopular       Boolean  @default(false)
  metaTitle       String?
  metaDescription String?
  content         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([stateCode])
  @@index([isPopular])
}

model Location {
  id        String        @id @default(cuid())
  code      String        @unique
  name      String
  country   String
  type      LocationType  @default(STATE)
  isPopular Boolean       @default(false)
  isActive  Boolean       @default(true)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  fees      LocationFee[]

  @@index([country])
  @@index([type])
  @@index([isActive, isPopular])
  @@index([country, type])
}

model LocationFee {
  id             String   @id @default(cuid())
  serviceId      String
  locationId     String
  feeType        FeeType  @default(FILING)
  label          String?
  amountUSD      Decimal  @db.Decimal(10, 2)
  amountBDT      Decimal? @db.Decimal(10, 2)
  processingTime String?
  isActive       Boolean  @default(true)
  isRequired     Boolean  @default(true)
  expeditedFee   Decimal? @db.Decimal(10, 2)
  expeditedTime  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locationId, feeType])
  @@index([serviceId])
  @@index([locationId])
  @@index([feeType])
  @@index([isActive])
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  description String?
  type        CouponType @default(PERCENTAGE)
  value       Decimal    @db.Decimal(10, 2)
  minOrder    Decimal?   @db.Decimal(10, 2)
  maxDiscount Decimal?   @db.Decimal(10, 2)
  usageLimit  Int?
  usedCount   Int        @default(0)
  isActive    Boolean    @default(true)
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  orders      Order[]

  @@index([code])
  @@index([isActive])
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  userId                String
  type                  String   @default("card")
  brand                 String?
  last4                 String
  expiryMonth           Int?
  expiryYear            Int?
  cardholderName        String?
  stripePaymentMethodId String?  @unique
  stripeCustomerId      String?
  isDefault             Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripePaymentMethodId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model LegalPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         String
  isActive        Boolean  @default(true)
  metaTitle       String?
  metaDescription String?
  version         Int      @default(1)
  lastUpdatedBy   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

model ServiceFormTemplate {
  id        String    @id @default(cuid())
  serviceId String    @unique
  version   Int       @default(1)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tabs      FormTab[]
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model FormTab {
  id          String              @id @default(cuid())
  templateId  String
  name        String
  description String?
  icon        String?
  order       Int
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  fields      FormField[]
  template    ServiceFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
}

model FormField {
  id               String          @id @default(cuid())
  tabId            String
  name             String
  label            String
  type             FieldType
  placeholder      String?
  helpText         String?
  order            Int
  width            FieldWidth      @default(FULL)
  required         Boolean         @default(false)
  validation       Json?
  options          Json?
  dataSourceType   DataSourceType?
  dataSourceKey    String?
  dependsOn        String?
  conditionalLogic Json?
  accept           String?
  maxSize          Int?
  defaultValue     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tab              FormTab         @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@index([tabId, order])
}

model SystemList {
  id             String           @id @default(cuid())
  key            String           @unique
  name           String
  description    String?
  type           String
  isEditable     Boolean          @default(false)
  isHierarchical Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  items          SystemListItem[]
}

model SystemListItem {
  id        String           @id @default(cuid())
  listId    String
  value     String
  label     String
  code      String?
  icon      String?
  metadata  Json?
  parentId  String?
  order     Int              @default(0)
  isPopular Boolean          @default(false)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  list      SystemList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  parent    SystemListItem?  @relation("ItemHierarchy", fields: [parentId], references: [id])
  children  SystemListItem[] @relation("ItemHierarchy")

  @@unique([listId, value])
  @@index([listId, parentId])
  @@index([listId, isPopular])
}

model CustomList {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       CustomListItem[]
}

model CustomListItem {
  id          String     @id @default(cuid())
  listId      String
  value       String
  label       String
  description String?
  metadata    Json?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  list        CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId, order])
}

model FormSubmission {
  id              String               @id @default(cuid())
  orderId         String
  templateId      String
  templateVersion Int
  data            Json
  status          SubmissionStatus     @default(DRAFT)
  submittedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  order           Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  files           FormSubmissionFile[]

  @@index([orderId])
  @@index([templateId])
}

model FormSubmissionFile {
  id           String         @id @default(cuid())
  submissionId String
  fieldName    String
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  createdAt    DateTime       @default(now())
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model HeaderConfig {
  id               String       @id @default(cuid())
  name             String       @default("Default Header")
  isActive         Boolean      @default(true)
  layout           HeaderLayout @default(DEFAULT)
  sticky           Boolean      @default(true)
  transparent      Boolean      @default(false)
  topBarEnabled    Boolean      @default(false)
  topBarContent    Json?
  topBarBgColor    String?
  topBarTextColor  String?
  logoPosition     LogoPosition @default(LEFT)
  logoMaxHeight    Int          @default(56)
  ctaButtons       Json?
  showAuthButtons  Boolean      @default(true)
  loginText        String       @default("Sign In")
  registerText     String       @default("Get Started")
  registerUrl      String       @default("/services/llc-formation")
  searchEnabled    Boolean      @default(false)
  mobileBreakpoint Int          @default(1024)
  bgColor          String?
  textColor        String?
  accentColor      String?
  borderColor      String?
  height           Int          @default(64)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  loginStyle       Json?
  loginUrl         String       @default("/login")
  registerStyle    Json?
  hoverColor       String?
  menuItems        MenuItem[]
}

model MenuItem {
  id              String        @id @default(cuid())
  label           String
  url             String?
  target          String        @default("_self")
  icon            String?
  parentId        String?
  isMegaMenu      Boolean       @default(false)
  megaMenuColumns Int?          @default(4)
  megaMenuContent Json?
  isVisible       Boolean       @default(true)
  visibleOnMobile Boolean       @default(true)
  requiredRole    String?
  badge           String?
  badgeColor      String?
  categoryName    String?
  categoryIcon    String?
  categoryDesc    String?
  sortOrder       Int           @default(0)
  headerId        String?
  footerWidgetId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  footerWidget    FooterWidget? @relation(fields: [footerWidgetId], references: [id], onDelete: Cascade)
  header          HeaderConfig? @relation(fields: [headerId], references: [id], onDelete: Cascade)
  parent          MenuItem?     @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children        MenuItem[]    @relation("MenuHierarchy")

  @@index([parentId])
  @@index([headerId])
  @@index([footerWidgetId])
  @@index([sortOrder])
}

model FooterConfig {
  id                   String         @id @default(cuid())
  name                 String         @default("Default Footer")
  isActive             Boolean        @default(true)
  layout               FooterLayout   @default(MULTI_COLUMN)
  columns              Int            @default(4)
  newsletterEnabled    Boolean        @default(true)
  newsletterTitle      String         @default("Subscribe to our newsletter")
  newsletterSubtitle   String?
  newsletterProvider   String?
  newsletterFormAction String?
  showSocialLinks      Boolean        @default(true)
  socialPosition       String         @default("brand")
  showContactInfo      Boolean        @default(true)
  contactPosition      String         @default("brand")
  bottomBarEnabled     Boolean        @default(true)
  copyrightText        String?
  showDisclaimer       Boolean        @default(true)
  disclaimerText       String?
  bottomLinks          Json?
  showTrustBadges      Boolean        @default(false)
  trustBadges          Json?
  bgColor              String?
  textColor            String?
  accentColor          String?
  borderColor          String?
  paddingTop           Int            @default(48)
  paddingBottom        Int            @default(32)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  animationDuration    Int            @default(300)
  bgGradient           Json?
  bgImage              String?
  bgImageOverlay       String?
  bgPattern            String?
  bgPatternColor       String?
  bgPatternOpacity     Float?         @default(0.1)
  bgType               String         @default("solid")
  bodyFont             String?
  borderRadius         Int            @default(0)
  bottomBarLayout      String         @default("split")
  containerStyle       String         @default("sharp")
  containerWidth       String         @default("full")
  cornerRadiusBL       Int            @default(0)
  cornerRadiusBR       Int            @default(0)
  cornerRadiusTL       Int            @default(0)
  cornerRadiusTR       Int            @default(0)
  customCSS            String?
  customJS             String?
  dividerColor         String?
  dividerStyle         String         @default("solid")
  enableAnimations     Boolean        @default(false)
  entranceAnimation    String?
  headingColor         String?
  headingFont          String?
  headingSize          String         @default("sm")
  headingStyle         String         @default("normal")
  headingWeight        String         @default("semibold")
  linkColor            String?
  linkHoverColor       String?
  linkHoverEffect      String         @default("color")
  presetId             String?
  responsiveColumns    Json?
  sectionOrder         String[]       @default(["widgets", "newsletter", "trust", "bottom"])
  shadow               String         @default("none")
  socialBgStyle        String         @default("subtle")
  socialColorMode      String         @default("brand")
  socialHoverEffect    String         @default("scale")
  socialShape          String         @default("circle")
  socialSize           String         @default("md")
  topBorderColor       String?
  topBorderHeight      Int            @default(4)
  topBorderStyle       String         @default("none")
  preset               FooterPreset?  @relation(fields: [presetId], references: [id])
  widgets              FooterWidget[]
}

model FooterPreset {
  id           String         @id @default(cuid())
  name         String
  description  String?
  category     String         @default("professional")
  thumbnail    String?
  config       Json
  isBuiltIn    Boolean        @default(false)
  isPublic     Boolean        @default(true)
  usageCount   Int            @default(0)
  tags         String[]
  colorPalette Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  footers      FooterConfig[]

  @@index([category])
  @@index([isBuiltIn])
  @@index([isPublic])
}

model FooterWidget {
  id          String           @id @default(cuid())
  footerId    String
  type        FooterWidgetType
  title       String?
  showTitle   Boolean          @default(true)
  content     Json?
  column      Int              @default(1)
  sortOrder   Int              @default(0)
  customClass String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  footer      FooterConfig     @relation(fields: [footerId], references: [id], onDelete: Cascade)
  menuItems   MenuItem[]

  @@index([footerId])
  @@index([column, sortOrder])
}

model NewsletterSubscriber {
  id             String                     @id @default(cuid())
  email          String                     @unique
  name           String?
  status         NewsletterSubscriberStatus @default(ACTIVE)
  source         String?
  subscribedAt   DateTime                   @default(now())
  unsubscribedAt DateTime?
  confirmedAt    DateTime?
  metadata       Json?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([status])
  @@index([subscribedAt])
}

model LandingPage {
  id               String             @id @default(cuid())
  slug             String             @unique
  name             String
  isActive         Boolean            @default(true)
  isDefault        Boolean            @default(false)
  metaTitle        String?
  metaDescription  String?
  ogImage          String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  publishedAt      DateTime?
  version          Int                @default(1)
  isTemplateActive Boolean            @default(false)
  templateType     PageTemplateType?
  isSystem         Boolean            @default(false)
  blocks           LandingPageBlock[]

  @@index([slug])
  @@index([isActive, isDefault])
  @@index([templateType, isTemplateActive])
}

model LandingPageBlock {
  id            String      @id @default(cuid())
  landingPageId String
  type          String
  name          String?
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)
  settings      Json
  hideOnMobile  Boolean     @default(false)
  hideOnDesktop Boolean     @default(false)
  variant       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([landingPageId, sortOrder])
  @@index([landingPageId, isActive])
}

model BlockTemplate {
  id        String   @id @default(cuid())
  name      String
  category  String
  type      String
  settings  Json
  thumbnail String?
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([type])
}

model Plugin {
  id                String           @id @default(cuid())
  slug              String           @unique
  name              String
  description       String?
  version           String
  author            String?
  authorUrl         String?
  icon              String?
  status            PluginStatus     @default(INSTALLED)
  manifest          Json?
  adminMenuLabel    String?
  adminMenuIcon     String?
  adminMenuPosition Int?
  hasAdminPages     Boolean          @default(false)
  hasPublicPages    Boolean          @default(false)
  hasWidgets        Boolean          @default(false)
  hasApiRoutes      Boolean          @default(false)
  installedAt       DateTime         @default(now())
  installedBy       String?
  lastActivatedAt   DateTime?
  lastError         String?
  errorAt           DateTime?
  updatedAt         DateTime         @updatedAt
  licenseExpiresAt  DateTime?
  licenseKey        String?
  licensePublicKey  String?
  licenseTier       String?
  licenseToken      String?
  licenseType       String?
  licenseVerifiedAt DateTime?
  licensedDomain    String?
  pluginPath        String?
  requiresLicense   Boolean          @default(true)
  menuItems         PluginMenuItem[]
  settings          PluginSetting[]

  @@index([slug])
  @@index([status])
}

model PluginSetting {
  id        String   @id @default(cuid())
  pluginId  String
  key       String
  value     String
  type      String   @default("string")
  updatedAt DateTime @updatedAt
  plugin    Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, key])
  @@index([pluginId])
}

model PluginMenuItem {
  id          String  @id @default(cuid())
  pluginId    String
  label       String
  path        String
  icon        String?
  parentLabel String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  plugin      Plugin  @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@index([pluginId])
  @@index([isActive])
}

model KnowledgeDocument {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  tags      String[]
  embedding Float[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model AIResponse {
  id         String        @id @default(cuid())
  ticketId   String
  content    String
  confidence Float         @default(0)
  sources    String[]
  wasUsed    Boolean       @default(false)
  wasEdited  Boolean       @default(false)
  usedAt     DateTime?
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([wasUsed])
  @@index([createdAt])
}

model Lead {
  id               String            @id @default(cuid())
  firstName        String
  lastName         String?
  email            String
  phone            String?
  company          String?
  country          String?
  city             String?
  status           LeadStatus        @default(NEW)
  source           LeadSource        @default(WEBSITE)
  sourceDetail     String?
  score            Int               @default(0)
  scoreHistory     Json?
  scoreDecayDays   Int               @default(0)
  priority         LeadPriority      @default(MEDIUM)
  pageViews        Int               @default(0)
  lastPageViewed   String?
  visitCount       Int               @default(1)
  lastActivityAt   DateTime          @default(now())
  assignedToId     String?
  assignedAt       DateTime?
  interestedIn     String[]
  budget           String?
  timeline         String?
  customFields     Json?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmTerm          String?
  utmContent       String?
  convertedAt      DateTime?
  convertedToId    String?
  notes            String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  formTemplateId   String?
  formTemplateName String?
  assignedTo       User?             @relation("AssignedLeads", fields: [assignedToId], references: [id])
  formTemplate     LeadFormTemplate? @relation(fields: [formTemplateId], references: [id])
  activities       LeadActivity[]
  leadNotes        LeadNote[]

  @@index([email])
  @@index([status])
  @@index([source])
  @@index([assignedToId])
  @@index([score])
  @@index([createdAt])
  @@index([priority])
  @@index([formTemplateId])
}

model LeadActivity {
  id            String   @id @default(cuid())
  leadId        String
  type          String
  description   String
  metadata      Json?
  performedById String?
  createdAt     DateTime @default(now())
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  performedBy   User?    @relation("PerformedActivities", fields: [performedById], references: [id])

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  content   String
  isPinned  Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("AuthoredLeadNotes", fields: [authorId], references: [id])
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([authorId])
}

model LeadFormTemplate {
  id              String    @id @default(cuid())
  name            String
  description     String?
  fields          Json
  defaultStyling  Json?
  isActive        Boolean   @default(true)
  isSystem        Boolean   @default(false)
  usageCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  autoAssignToId  String?
  lastSubmission  DateTime?
  submissionCount Int       @default(0)
  successMessage  String?
  successRedirect String?
  leads           Lead[]

  @@index([isActive])
}

model TrackingSettings {
  id                  String   @id @default(cuid())
  gtmEnabled          Boolean  @default(false)
  gtmContainerId      String?
  gtmTrackForms       Boolean  @default(true)
  gtmTrackPages       Boolean  @default(true)
  fbPixelEnabled      Boolean  @default(false)
  fbPixelId           String?
  fbTrackLead         Boolean  @default(true)
  fbTrackPageView     Boolean  @default(true)
  fbTrackContent      Boolean  @default(false)
  gadsEnabled         Boolean  @default(false)
  gadsConversionId    String?
  gadsConversionLabel String?
  gadsDefaultValue    Float?
  tiktokEnabled       Boolean  @default(false)
  tiktokPixelId       String?
  updatedAt           DateTime @updatedAt
}

model ActiveTheme {
  id                   String   @id @default(cuid())
  themeId              String   @unique
  themeName            String
  activatedAt          DateTime @default(now())
  colorPalette         Json?
  fontConfig           Json?
  originalColorPalette Json?

  @@index([themeId])
}

