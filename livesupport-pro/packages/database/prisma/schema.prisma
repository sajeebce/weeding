// LiveSupport Pro - Prisma Schema
// This schema can be used standalone or integrated with existing databases

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH (can be extended or linked to host application)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Support relations
  tickets            SupportTicket[] @relation("CustomerTickets")
  assignedTickets    SupportTicket[] @relation("AssignedTickets")
  messages           SupportMessage[]
  internalNotes      InternalNote[]
  chatSessions       ChatSession[]   @relation("AssignedChats")
  notifications      Notification[]
  cannedResponses    CannedResponse[]
  agentAvailability  AgentAvailability?

  @@index([email])
  @@index([role])
}

enum UserRole {
  CUSTOMER
  SUPPORT_AGENT
  ADMIN
  CONTENT_MANAGER
  SALES_AGENT
}

// ============================================================================
// SUPPORT TICKETS
// ============================================================================

model SupportTicket {
  id            String         @id @default(cuid())
  ticketNumber  String         @unique
  subject       String
  description   String         @db.Text
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(NORMAL)
  category      String?
  tags          String[]       @default([])

  // Relations
  customerId    String
  customer      User           @relation("CustomerTickets", fields: [customerId], references: [id], onDelete: Cascade)
  assignedToId  String?
  assignedTo    User?          @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  departmentId  String?
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Messages and notes
  messages      SupportMessage[]
  internalNotes InternalNote[]
  attachments   TicketAttachment[]

  // Timestamps
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // SLA tracking
  slaDeadline   DateTime?
  slaPaused     Boolean   @default(false)
  slaPausedAt   DateTime?

  // Metadata
  metadata      Json      @default("{}")
  source        TicketSource @default(WEB)

  @@index([customerId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([createdAt(sort: Desc)])
  @@index([ticketNumber])
}

enum TicketStatus {
  OPEN
  WAITING_FOR_CUSTOMER
  WAITING_FOR_AGENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketSource {
  WEB
  EMAIL
  CHAT
  API
}

// ============================================================================
// MESSAGES
// ============================================================================

model SupportMessage {
  id          String      @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content     String      @db.Text
  contentHtml String?     @db.Text
  type        MessageType @default(TEXT)
  senderType  SenderType
  senderName  String
  senderId    String?
  sender      User?       @relation(fields: [senderId], references: [id], onDelete: SetNull)
  isRead      Boolean     @default(false)
  readAt      DateTime?
  attachments MessageAttachment[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt(sort: Asc)])
}

enum MessageType {
  TEXT
  HTML
  SYSTEM
  AI
}

enum SenderType {
  CUSTOMER
  AGENT
  SYSTEM
  AI
}

model MessageAttachment {
  id        String         @id @default(cuid())
  messageId String
  message   SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime       @default(now())

  @@index([messageId])
}

model TicketAttachment {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

// ============================================================================
// INTERNAL NOTES
// ============================================================================

model InternalNote {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content   String        @db.Text
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mentions  String[]      @default([])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([ticketId])
  @@index([authorId])
}

// ============================================================================
// LIVE CHAT
// ============================================================================

model ChatSession {
  id              String      @id @default(cuid())
  visitorId       String
  visitorName     String
  visitorEmail    String?
  department      String?
  status          ChatStatus  @default(WAITING)
  assignedAgentId String?
  assignedAgent   User?       @relation("AssignedChats", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  messages        ChatMessage[]
  metadata        Json        @default("{}")
  acceptedAt      DateTime?
  endedAt         DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Rating after chat
  rating          Int?
  ratingComment   String?

  @@index([visitorId])
  @@index([assignedAgentId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum ChatStatus {
  WAITING
  ACTIVE
  ENDED
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content     String      @db.Text
  senderType  ChatSenderType
  senderId    String?
  senderName  String
  createdAt   DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt(sort: Asc)])
}

enum ChatSenderType {
  VISITOR
  AGENT
  AI
  SYSTEM
}

// ============================================================================
// DEPARTMENTS
// ============================================================================

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  email       String?
  isActive    Boolean  @default(true)
  tickets     SupportTicket[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
}

enum NotificationType {
  NEW_TICKET
  NEW_MESSAGE
  TICKET_ASSIGNED
  TICKET_UPDATED
  MENTION
  CHAT_REQUEST
}

// ============================================================================
// CANNED RESPONSES
// ============================================================================

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  shortcut  String?
  category  String?
  isGlobal  Boolean  @default(false)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shortcut])
  @@index([authorId])
  @@index([isGlobal])
}

// ============================================================================
// AGENT AVAILABILITY
// ============================================================================

model AgentAvailability {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        AgentStatus @default(OFFLINE)
  maxChats      Int         @default(5)
  currentChats  Int         @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
}

enum AgentStatus {
  ONLINE
  AWAY
  BUSY
  OFFLINE
}

// ============================================================================
// SUPPORT SETTINGS
// ============================================================================

model SupportSettings {
  id                    String   @id @default(cuid())
  businessHoursEnabled  Boolean  @default(false)
  businessHoursStart    String?  // "09:00"
  businessHoursEnd      String?  // "18:00"
  businessDays          String[] @default(["Mon", "Tue", "Wed", "Thu", "Fri"])
  timezone              String   @default("UTC")
  autoAssignEnabled     Boolean  @default(false)
  autoReplyEnabled      Boolean  @default(false)
  autoReplyMessage      String?  @db.Text
  chatWidgetEnabled     Boolean  @default(true)
  chatWidgetPosition    String   @default("bottom-right")
  chatWidgetColor       String   @default("#2563eb")
  chatWidgetTitle       String   @default("Live Support")
  chatWidgetSubtitle    String   @default("We typically reply within minutes")
  slaEnabled            Boolean  @default(false)
  slaResponseTime       Int?     // in minutes
  slaResolutionTime     Int?     // in minutes
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================================================
// AI KNOWLEDGE BASE
// ============================================================================

model KnowledgeDocument {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  category    String?
  tags        String[] @default([])
  isPublished Boolean  @default(false)
  embedding   Bytes?   // Vector embedding for AI search
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
}

model AIConversationLog {
  id          String   @id @default(cuid())
  sessionId   String?
  ticketId    String?
  query       String   @db.Text
  response    String   @db.Text
  confidence  Float?
  wasHelpful  Boolean?
  feedback    String?
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([ticketId])
  @@index([createdAt(sort: Desc)])
}
