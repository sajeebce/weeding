{
  "name": "livesupport-pro",
  "version": "1.0.0",
  "private": true,
  "description": "Modern live chat & ticketing system with AI support",
  "author": "LLCPad",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "standalone:dev": "turbo run dev --filter=@livesupport/standalone",
    "standalone:build": "turbo run build --filter=@livesupport/standalone",
    "plugin:build": "turbo run build --filter=@livesupport/llcpad-plugin",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0",
    "@types/node": "^22.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
